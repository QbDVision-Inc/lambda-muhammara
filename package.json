{
  "name": "lambda-muhammara",
  "version": "6.0.5",
  "description": "Muhammara 6.0.5 binaries that can be used in Lambda, built for the Node 22.x (nodejs22.x) runtime on 64-bit (x86) architecture.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QbDVision-Inc/lambda-muhammara.git"
  },
  "main": "install.js",
  "files": [
    "install.js",
    "binding/muhammara.node",
    "binding/muhammara.node.zip"
  ],
  "scripts": {
    "prepare": "node install.js",
    "release": "node scripts/release.js"
  },
  "keywords": [
    "lambda-muhammara",
    "muhammara"
  ],
  "readmeFilename": "README.md",
  "license": "MIT",
  "peerDependencies": {
    "muhammara": "6.0.5"
  },
  "devDependencies": {
    "extract-zip": "^2.0.1"
  },
  "engines": {
    "node": ">= 20.18.1 <23"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=12.0.0",
      "onFail": "error"
    }
  },
  "allowScripts": {
    "muhammara@6.0.5": true
  }
}
