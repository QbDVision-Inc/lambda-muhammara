  },
  "keywords": [
    "lambda-muhammara",
    "muhammara"
  ],
  "readmeFilename": "README.md",
  "license": "MIT",
  "dependencies": {
    "extract-zip": "^2.0.1",
    "muhammara": "^5.3.0"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "overrides": {
    "semver": "7.5.4"
  }
