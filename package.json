{
  "name": "lambda-muhammara",
  "version": "5.3.1",
  "description": "Muhammara 5.3.1 binaries that can be used in Lambda that were built on Node 20.x on 64-bit (x86) architecture.",
  "repository": {
    "type": "git",
    "url": "https://github.com/QbDVision-Inc/lambda-muhammara.git"
  },
  "main": "install.js",
  "scripts": {
